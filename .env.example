# Copy to .env and fill in. The app boots without any keys (hashing embeddings,
# but LLM calls will fail until ANTHROPIC_API_KEY is set).

ANTHROPIC_API_KEY=sk-ant-...

# Optional. When set together with EMBEDDING_PROVIDER=voyage, real semantic
# embeddings are used. Without it the app falls back to local hashing embeddings
# (lexical-only, fine for development).
VOYAGE_API_KEY=

DATABASE_URL=postgresql+psycopg://nexus:nexus@localhost:5432/nexus

LLM_MODEL=claude-opus-4-8
EMBEDDING_PROVIDER=hashing   # voyage | hashing
EMBEDDING_DIM=1024

# Self-improving RAG toggles (all default on)
REWRITE_ENABLED=true
RERANK_ENABLED=true
GRADING_ENABLED=true

# Auth: unset = single-user dev mode (no auth). Set a long random string to
# require JWT bearer tokens; mint them with: python scripts/make_token.py
AUTH_SECRET=
AUTH_TOKEN_TTL_MINUTES=60
